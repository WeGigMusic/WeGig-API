generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Gig {
  id              String   @id @default(uuid())
  userId          String
  artist          String
  artistMbid      String?
  venue           String
  city            String
  date            String
  rating          Int?
  notes           String?
  externalSource  String?
  externalId      String?
  ticketUrl       String?
  venueLatitude   Float?
  venueLongitude  Float?
  venuePlaceName  String?
  venuePlaceId    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([userId, date])
  @@index([userId, artist, date])
  @@unique([userId, externalSource, externalId])
}